# Environment variables
backend/.env

# Dependencies
backend/node_modules/
frontend/node_modules/

# Build outputs
frontend/dist/

# Storage files (except .gitkeep files for empty directories)
backend/storage/**
!backend/storage/attachments/.gitkeep
!backend/storage/tmp/.gitkeep
!backend/storage/quarantine/.gitkeep

# Python services
backend/python-services/**/__pycache__/
backend/python-services/**/*.pyc
backend/python-services/**/.pytest_cache/

# Hardhat files
backend/hardhat-local/artifacts/
backend/hardhat-local/cache/
backend/hardhat-local/deployments/local.json
backend/artifacts/
backend/cache/

# Logs
*.log
logs
*.logs

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# IDEs and editors
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~.swp
.DS_Store
Thumbs.db

# OS generated files
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package manager lock files (optional - you may want to commit these)
# package-lock.json
# npm-shrinkwrap.json
# yarn.lock

# Local development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

